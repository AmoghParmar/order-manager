VITE_I18N_LOCALE=en-US
VITE_I18N_FALLBACK_LOCALE=en-US
VITE_CACHE_MAX_AGE=3600
VITE_VIEW_SIZE=10
VITE_ALIAS=
VITE_DEFAULT_ALIAS=
VITE_APP_PERMISSION_ID=ORDERMGR_VIEW
VITE_DEFAULT_LOG_LEVEL=error
VITE_AUTH_BACKEND=ofbiz
VITE_MOQUI_BASE_URL=
VITE_LAUNCHPAD_URL=http://launchpad.hotwax.io/login
VITE_OMS_TYPE=
VITE_DEFAULT_PRODUCT_STORE_SETTINGS={"PRDT_IDEN_PREF":{"stateKey":"productIdentifier.productIdentificationPref","value":{"primaryId":"SKU","secondaryId":"productId"}},"BARCODE_IDEN_PREF":{"stateKey":"barcodeIdentifier.barcodeIdentifierPref","value":"SKU"}}

# --- Fast Travel (Cmd/Ctrl+K app switcher) ---
# Base URLs of sibling HotWax admin apps (VITE_LAUNCHPAD_URL above is also used). Blank = that app
# shows as "Not configured" in the palette for this deployment.
VITE_JOB_MANAGER_URL=
VITE_ORDER_MANAGER_URL=
VITE_ORDER_ROUTING_URL=
VITE_COMPANY_URL=
VITE_PRODUCTS_URL=

# Dev-only auto-login. Copy this file to .env.local and fill in credentials locally.
VITE_DEV_OMS=localhost:8080
VITE_DEV_USERNAME=
VITE_DEV_PASSWORD=
VITE_DEV_AUTO_LOGIN=true
